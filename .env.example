# ── Copy this file to ".env" and fill in your keys ──────────────────────────

# Anthropic key — powers the 3 text gems (NB Frames, Kling, NB Advisor).
# Get it at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini key — powers Nano Banana 2 image generation.
# Get it at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model the text gems use. Haiku 4.5 is the cheapest current model
# ($1 / $5 per million tokens) — best for high volume. For stricter adherence to the
# NB Frames 4-paragraph structure, bump to claude-sonnet-4-6 ($3 / $15).
CLAUDE_MODEL=claude-haiku-4-5

# Nano Banana 2 model id (Gemini 3.1 Flash Image, GA). Newest, near-Pro quality,
# ~half the cost & faster. For max fidelity / native 4K / best text rendering,
# switch to Nano Banana Pro: gemini-3-pro-image (~2x the cost).
NB2_MODEL=gemini-3.1-flash-image

# Image size: 1K | 2K | 4K. 1K is the value sweet spot.
NB2_IMAGE_SIZE=1K

# Port for the local server.
PORT=4505

# ── Cloud / multi-user (Phase 1 — leave blank until set up) ──────────────────
# Storage + metadata backends. "local" = disk/JSON (default, today).
# Phase 1 switches these to "drive" / "postgres" once the cloud is wired.
STORAGE_BACKEND=local
DATA_BACKEND=local

# Google OAuth client — powers "Sign in with Google" + Drive access.
# Create at https://console.cloud.google.com (APIs & Services → Credentials),
# enable the Google Drive API, add both users as Test users on the consent screen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only these emails may log in (comma-separated). Everyone else is denied.
ALLOWLIST_EMAILS=yossi.bozo112@gmail.com,liransegal@gmail.com
